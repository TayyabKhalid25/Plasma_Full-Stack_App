# Environment Variables for Server (Node.js)
# ===============================================================
# ZERO-CLOUD VAULT INSTRUCTIONS:
# 1. To encrypt your .env: Run 'npm run encrypt'
# 2. To decrypt secrets.enc: Run 'npm run decrypt'
# 3. Share the Team Password privately with your teammates.
# ===============================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit your .env file to GitHub.

# Neon PostgreSQL connection strings
# (Found in your Neon Project Dashboard under 'Connection String')
DATABASE_URL_POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
DATABASE_URL_PGUSER=YOUR_USER_NAME_HERE
DATABASE_URL_PGDATABASE=YOUR_DB_NAME_HERE
DATABASE_URL_UNPOOLED=YOUR_UNPOOLED_CONNECTION_STRING_HERE
DATABASE_URL_PGPASSWORD=YOUR_PASSWORD_HERE
DATABASE_URL_POSTGRES_URL_NON_POOLING=YOUR_NON_POOLING_URL_HERE
DATABASE_URL_POSTGRES_HOST=YOUR_ENDPOINT_HOSTNAME_HERE
DATABASE_URL_PGHOST=YOUR_ENDPOINT_HOSTNAME_HERE
DATABASE_URL_POSTGRES_URL_NO_SSL=YOUR_URL_WITHOUT_SSL_HERE
DATABASE_URL_POSTGRES_PRISMA_URL=YOUR_PRISMA_FORMAT_URL_HERE
DATABASE_URL_POSTGRES_DATABASE=YOUR_DB_NAME_HERE
DATABASE_URL_POSTGRES_USER=YOUR_USER_NAME_HERE
DATABASE_URL_NEON_AUTH_BASE_URL=YOUR_NEON_AUTH_URL_HERE
DATABASE_URL_PGHOST_UNPOOLED=YOUR_UNPOOLED_HOSTNAME_HERE
DATABASE_URL_DATABASE_URL=YOUR_POOLED_CONNECTION_STRING_HERE
DATABASE_URL_POSTGRES_URL=YOUR_POOLED_CONNECTION_STRING_HERE
DATABASE_URL_NEON_PROJECT_ID=YOUR_PROJECT_ID_HERE
DATABASE_URL_VITE_NEON_AUTH_URL=YOUR_NEON_AUTH_URL_HERE

# The primary connection string used by the app logic
DATABASE_URL=YOUR_FULL_DATABASE_URL_HERE

# Server Configuration
PORT=YOUR_PORT_NUMBER_HERE
FRONTEND_URL=YOUR_FRONTEND_URL_HERE
JWT_SECRET=YOUR_JWT_SECRET_HERE
BCRYPT_COST_FACTOR=5

# External API Keys (Optional/If applicable)
# IGDB API Keys
IGDB_CLIENT_ID=YOUR_IGDB_CLIENT_ID_HERE
IGDB_CLIENT_SECRET=YOUR_IGDB_CLIENT_SECRET_HERE

# Steam API Key
STEAM_API_KEY=YOUR_STEAM_API_KEY_HERE