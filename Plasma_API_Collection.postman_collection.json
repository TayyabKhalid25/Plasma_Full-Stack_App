						],
						"url": {
							"raw": "http://localhost:5000/api/rallies?view=calendar",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "rallies" ],
							"query": [
								{ "key": "view", "value": "calendar", "description": "Options: calendar, list" }
							]
						}
					}
				},
				{
