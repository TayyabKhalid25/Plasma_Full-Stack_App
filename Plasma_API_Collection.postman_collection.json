{
	"info": {
		"_postman_id": "a97d16ee-d308-4bc2-91f5-aa91069cf870",
		"name": "Plasma API",
		"description": "API Documentation for the Plasma backend. Contains all routes required for the frontend integration.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Traditional Register (Create Account)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"NewGamer123\",\n    \"email\": \"newgamer@test.com\",\n    \"password\": \"MySecurePassword1!\",\n    \"dateOfBirth\": \"2000-01-01\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/auth/register",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "auth", "register" ]
						},
						"description": "Registers a new user with an email and password. Returns a JWT token."
					}
				},
				{
					"name": "Traditional Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"wahaj@plasma.gg\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/auth/login",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "auth", "login" ]
						},
						"description": "Logs in an existing user using email or username, and their password. Returns a JWT token."
					}
				},
				{
					"name": "Dev Login (Generate Token)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"Wahaj\",\n    \"steamID64\": \"76561198000000001\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/auth/dev-login",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "auth", "dev-login" ]
						},
						"description": "Use this to log in. Copy the `token` from the response and use it in the Authorization header for all other requests. Other seeded users: Ahmed, Sarah, Ali, Omar."
					}
				},
				{
					"name": "Get Current User Profile (/me)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/auth/me",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "auth", "me" ]
						}
					}
				}
			]
		},
		{
			"name": "2. Social & Feed",
			"item": [
				{
					"name": "Get Pulse Feed",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/feed?filter=all",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "feed" ],
							"query": [
								{ "key": "filter", "value": "all", "description": "Options: all, my-posts, comp, chill, friends" }
							]
						}
					}
				},
				{
					"name": "Get Friends List",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/friends",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "friends" ]
						}
					}
				},
				{
					"name": "Get Online Squad",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/squad",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "squad" ]
						}
					}
				}
			]
		},
		{
			"name": "3. Gaming & Progression",
			"item": [
				{
					"name": "Get Games Library",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/games?filter=all&search=",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "games" ],
							"query": [
								{ "key": "filter", "value": "all", "description": "Options: all, playing, steam, non-steam" },
								{ "key": "search", "value": "", "description": "Search by game title" }
							]
						}
					}
				},
				{
					"name": "Get Prestige Achievements",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/achievements?type=steam",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "achievements" ],
							"query": [
								{ "key": "type", "value": "steam", "description": "Platform filter" }
							]
						}
					}
				},
				{
					"name": "Get Leaderboard",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/leaderboard?scope=friends",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "api", "leaderboard" ],
							"query": [
								{ "key": "scope", "value": "friends", "description": "Options: friends, global" }
							]
						}
					}
				}
			]
		},
		{
			"name": "4. Events & Rallies",
			"item": [
				{
					"name": "Get All Upcoming Rallies",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/rallies", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "rallies"] }
					}
				},
				{
					"name": "Get Upcoming Rallies (Right Rail Widget)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/rallies/upcoming", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "rallies", "upcoming"] }
					}
				},
				{
					"name": "Create a Rally",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"body": { "mode": "raw", "raw": "{\n    \"title\": \"Friday Night Ranked\",\n    \"description\": \"Competitive grind session\",\n    \"scheduledStartUTC\": \"2026-04-25T21:00:00.000Z\",\n    \"maxCapacity\": 5,\n    \"requiredIntent\": \"COMPETITIVE\"\n}" },
						"url": { "raw": "http://localhost:5000/api/rallies", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "rallies"] }
					}
				},
				{
					"name": "RSVP to a Rally",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"body": { "mode": "raw", "raw": "{\n    \"declaredRole\": \"DPS\"\n}" },
						"url": { "raw": "http://localhost:5000/api/rallies/{{RALLY_ID}}/rsvp", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "rallies", "{{RALLY_ID}}", "rsvp"] },
						"description": "Replace {{RALLY_ID}} with a real eventID from GET /api/rallies"
					}
				},
				{
					"name": "Cancel an RSVP",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/rallies/{{RALLY_ID}}/rsvp", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "rallies", "{{RALLY_ID}}", "rsvp"] }
					}
				},
				{
					"name": "Get User Settings",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/settings", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "settings"] }
					}
				}
			]
		},
		{
			"name": "5. Feed & Posts",
			"item": [
				{
					"name": "Get Feed",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/feed?filter=all", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "feed"], "query": [{ "key": "filter", "value": "all", "description": "Options: all, my-posts, comp, chill, friends" }] }
					}
				},
				{
					"name": "Create a Post",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"body": { "mode": "raw", "raw": "{\n    \"content\": \"Just hit Radiant! Let's go! 🎮\",\n    \"type\": \"MOMENT\",\n    \"mediaURL\": null\n}" },
						"url": { "raw": "http://localhost:5000/api/feed/posts", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "feed", "posts"] },
						"description": "type options: MOMENT, ACHIEVEMENT_UNLOCK, ACTIVITY_UPDATE, RALLY_BROADCAST"
					}
				},
				{
					"name": "Delete a Post",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/feed/posts/{{POST_ID}}", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "feed", "posts", "{{POST_ID}}"] }
					}
				}
			]
		},
		{
			"name": "6. Users",
			"item": [
				{
					"name": "Update My Intent (CHILL/COMP/OFFLINE)",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"body": { "mode": "raw", "raw": "{\n    \"intent\": \"COMPETITIVE\"\n}" },
						"url": { "raw": "http://localhost:5000/api/users/me/intent", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "users", "me", "intent"] },
						"description": "Options: COMPETITIVE, CHILL, OFFLINE"
					}
				},
				{
					"name": "Update My Profile",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"body": { "mode": "raw", "raw": "{\n    \"username\": \"NewUsername\",\n    \"bio\": \"My updated bio!\",\n    \"avatarURL\": \"https://example.com/avatar.png\"\n}" },
						"url": { "raw": "http://localhost:5000/api/users/me/profile", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "users", "me", "profile"] }
					}
				},
				{
					"name": "Search Users",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/users/search?q=Ahmed", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "users", "search"], "query": [{ "key": "q", "value": "Ahmed" }] }
					}
				},
				{
					"name": "Get Public User Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "http://localhost:5000/api/users/{{USER_ID}}", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "users", "{{USER_ID}}"] }
					}
				}
			]
		},
		{
			"name": "7. Friends & Social",
			"item": [
				{
					"name": "Send Friend Request",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/friends/request/{{TARGET_USER_ID}}", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "friends", "request", "{{TARGET_USER_ID}}"] },
						"description": "Replace {{TARGET_USER_ID}} with the plasmaUserID from user search"
					}
				},
				{
					"name": "Unfollow / Remove Friend",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/friends/{{TARGET_USER_ID}}", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "friends", "{{TARGET_USER_ID}}"] }
					}
				}
			]
		},
		{
			"name": "8. Notifications, Messages & Trending",
			"item": [
				{
					"name": "Get Notifications",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/notifications?filter=all", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "notifications"], "query": [{ "key": "filter", "value": "all", "description": "Options: all, friend_request, achievement, rally" }] }
					}
				},
				{
					"name": "Get All Conversations",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/messages", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "messages"] }
					}
				},
				{
					"name": "Get Conversation with a Friend",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/messages/{{FRIEND_USER_ID}}", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "messages", "{{FRIEND_USER_ID}}"] }
					}
				},
				{
					"name": "Get Trending Games",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
						"url": { "raw": "http://localhost:5000/api/trending", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "trending"] }
					}
				}
			]
		}
	]
}
