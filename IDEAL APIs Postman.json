              "raw": "http://localhost:5000/api/rallies/:eventId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "rallies", ":eventId"],
              "variable": [{ "key": "eventId", "value": "rally_123" }]
            },
            "description": "Returns full Rally details: title, game, localized time, role slots with current RSVP counts and attendee list."
          }
        },
        {
          "name": "Create Rally (REQ-4, REQ-5)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Friday Night Ranked\",\n    \"gameId\": \"1234\",\n    \"utcStartTime\": \"2026-03-22T21:00:00.000Z\",\n    \"intent\": \"COMP\",\n    \"roles\": [\n        { \"name\": \"DPS\", \"capacity\": 3 },\n        { \"name\": \"Sentinel\", \"capacity\": 2 }\n    ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/rallies",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "rallies"]
            },
            "description": "Creates a new Rally event. UTC start time is stored as UTC and displayed to each viewer in their local timezone. Roles define squad slots (REQ-5). Intent field tags the event for filtering (REQ-14)."
          }
        },
        {
          "name": "Update Rally",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Friday Night Ranked — Rescheduled\",\n    \"utcStartTime\": \"2026-03-23T20:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/rallies/:eventId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "rallies", ":eventId"],
              "variable": [{ "key": "eventId", "value": "rally_123" }]
            },
            "description": "Allows the Rally creator to update event details. Attendees who have RSVP'd should be notified of the change."
          }
        },
        {
          "name": "Delete / Cancel Rally",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/rallies/:eventId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "rallies", ":eventId"],
              "variable": [{ "key": "eventId", "value": "rally_123" }]
            },
            "description": "Cancels and removes a Rally event. Only the creator can perform this action."
          }
        },
        {
          "name": "RSVP to Rally (REQ-5)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
