              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "rallies", ":eventId", "rsvp"],
              "variable": [{ "key": "eventId", "value": "rally_123" }]
            },
            "description": "RSVPs the authenticated user to a Rally by selecting a role slot (REQ-5)."
          }
