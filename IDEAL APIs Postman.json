{
  "info": {
    "_postman_id": "a97d16ee-d308-4bc2-91f5-aa91069cf870",
    "name": "IDEAL Plasma APIs — Complete",
    "description": "Complete API Documentation for the Plasma backend, fully aligned with the SRS v1.0. Covers all subsystems: The Pulse, The Rally, The Omni-Library, The Prestige, Intent Modes, Steam integrations, Direct Messaging (BR-2), and account lifecycle (GDPR).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Dev Login (Generate Token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"Wahaj\",\n    \"steamID64\": \"76561198000000001\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/dev-login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "dev-login"]
            },
            "description": "Dev-only login. Returns a JWT token. Seeded users: Wahaj, Ahmed, Sarah, Ali, Omar. Copy the `token` and set it in the Authorization header for all further requests."
          }
        },
        {
          "name": "Steam OpenID — Initiate Login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/auth/steam",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "steam"]
            },
            "description": "Redirects the browser to Valve's OpenID 2.0 endpoint to begin Steam authentication (BR-1). No password is ever stored by Plasma."
          }
        },
        {
          "name": "Steam OpenID — Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/auth/steam/callback",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "steam", "callback"]
            },
            "description": "Valve redirects here after the user approves the OpenID login. The backend validates the assertion, creates/fetches the PlasmaUser mapped to the SteamID64, and returns a session JWT."
          }
        },
        {
          "name": "Get Current User Profile (/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the authenticated user's full profile including SteamID64, PlasmaUserID, linked Steam data, current Intent Mode, and Plasma XP total."
          }
        },
        {
          "name": "Logout User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. User Profile & Settings",
      "item": [
        {
          "name": "Get Public User Profile (by userId)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/users/:userId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", ":userId"],
              "variable": [{ "key": "userId", "value": "12345" }]
            },
            "description": "Returns another user's public profile: username, Steam status, Intent Mode badge, Hall of Fame, Plasma XP, and mutual follow status."
          }
        },
        {
          "name": "Get User Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/settings",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "settings"]
            },
            "description": "Retrieves the authenticated user's application settings (notifications, privacy preferences, timezone, etc.)."
          }
        },
        {
          "name": "Update User Settings",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"notificationsEnabled\": true,\n    \"timezone\": \"Asia/Karachi\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/settings",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "settings"]
            },
            "description": "Persists user application settings."
          }
        },
        {
          "name": "Update Intent Mode (REQ-12)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"intent\": \"COMP\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/users/me/intent",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", "me", "intent"]
            },
            "description": "Toggles the user's global Intent Mode. Options: COMP, CHILL, OFFLINE. Broadcasts a status change event to The Pulse (REQ-12, REQ-13)."
          }
        },
        {
          "name": "Delete Account (GDPR — Right to be Forgotten)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/users/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", "me"]
            },
            "description": "Permanently queues the authenticated user's data for deletion within 30 days: SteamID64, social graph, posts, RSVPs, and Rally history. Satisfies GDPR/CCPA Right to be Forgotten requirement."
          }
        }
      ]
    },
    {
      "name": "3. Social & Feed (The Pulse)",
      "item": [
        {
          "name": "Get Pulse Feed (REQ-1, REQ-2)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/feed?filter=all",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "feed"],
              "query": [
                {
                  "key": "filter",
                  "value": "all",
                  "description": "Options: all, my-posts, friends"
                },
                {
                  "key": "intent",
                  "value": "COMP",
                  "description": "Optional Intent Mode filter: COMP, CHILL (REQ-14)"
                }
              ]
            },
            "description": "Returns the unified activity feed. Merges live Steam status events with user-generated Moments. Supports intent-based filtering (REQ-14)."
          }
        },
        {
          "name": "Create Post / Moment (REQ-2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Finally hit Platinum in the new Season!\",\n    \"mediaUrl\": \"https://example.com/clip.mp4\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/pulse/posts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "pulse", "posts"]
            },
            "description": "Publishes a text, image, or video clip Moment to the author's followers' Pulse feed."
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/pulse/posts/:postId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "pulse", "posts", ":postId"],
              "variable": [{ "key": "postId", "value": "98765" }]
            },
            "description": "Permanently removes a post authored by the authenticated user."
          }
        },
        {
          "name": "React to Post",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/pulse/posts/:postId/react",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "pulse", "posts", ":postId", "react"],
              "variable": [{ "key": "postId", "value": "98765" }]
            }
          }
        },
        {
          "name": "Get Comments on Post",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/pulse/posts/:postId/comments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "pulse", "posts", ":postId", "comments"],
              "variable": [{ "key": "postId", "value": "98765" }]
            },
            "description": "Fetches paginated comments for a specific post."
          }
        },
        {
          "name": "Add Comment to Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Let's go! GG!\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/pulse/posts/:postId/comments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "pulse", "posts", ":postId", "comments"],
              "variable": [{ "key": "postId", "value": "98765" }]
            }
          }
        },
        {
          "name": "Get Friends List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/friends",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "friends"]
            },
            "description": "Returns the authenticated user's Steam friends who are also on Plasma."
          }
        },
        {
          "name": "Get Online Squad",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/squad",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "squad"]
            },
            "description": "Returns the subset of followed users who are currently online/active (live Steam status + manual intent)."
          }
        },
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/users/:userId/follow",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", ":userId", "follow"],
              "variable": [{ "key": "userId", "value": "12345" }]
            },
            "description": "Follows a user. Mutual following unlocks Double Opt-In private interaction (BR-2)."
          }
        },
        {
          "name": "Unfollow User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/users/:userId/follow",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", ":userId", "follow"],
              "variable": [{ "key": "userId", "value": "12345" }]
            }
          }
        },
        {
          "name": "Get Followers for User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/users/:userId/followers",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", ":userId", "followers"],
              "variable": [{ "key": "userId", "value": "12345" }]
            }
          }
        },
        {
          "name": "Get Following for User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/users/:userId/following",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", ":userId", "following"],
              "variable": [{ "key": "userId", "value": "12345" }]
            }
          }
        }
      ]
    },
    {
      "name": "4. Steam Integration",
      "item": [
        {
          "name": "Sync Steam Library",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/library/sync/steam",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "library", "sync", "steam"]
            },
            "description": "Triggers a manual re-poll of the Steam Web API to sync the user's owned games and playtime data into the Plasma database."
          }
        },
        {
          "name": "Get Live Steam Status (Friends)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/steam/friends/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "steam", "friends", "status"]
            },
            "description": "Polls (or returns cached) live Steam statuses for the user's friend network via the Steam Web API. Powers The Pulse feed (REQ-1). Results are Redis-cached to respect Steam API rate limits."
          }
        },
        {
          "name": "Get Steam Player Summary (by SteamID64)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/steam/player/:steamId64",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "steam", "player", ":steamId64"],
              "variable": [{ "key": "steamId64", "value": "76561198000000001" }]
            },
            "description": "Returns the Steam player summary (avatar, persona name, current game) for the given SteamID64 via the Steam Web API GetPlayerSummaries endpoint."
          }
        },
        {
          "name": "Get Steam Achievements for Game",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/steam/achievements/:appId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "steam", "achievements", ":appId"],
              "variable": [{ "key": "appId", "value": "570" }]
            },
            "description": "Fetches the authenticated user's unlocked achievements for a specific Steam AppID along with global rarity percentages. Used by The Prestige (REQ-9) to calculate Plasma XP."
          }
        }
      ]
    },
    {
      "name": "5. Games Library (Omni-Library)",
      "item": [
        {
          "name": "Get Games Library",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/games?filter=all&search=",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "games"],
              "query": [
                { "key": "filter", "value": "all", "description": "Options: all, playing, steam, non-steam" },
                { "key": "search", "value": "", "description": "Search by game title" }
              ]
            },
            "description": "Returns the combined library of Steam-synced and manually added (Omni-Library) games for the authenticated user."
          }
        },
        {
          "name": "Search IGDB (Manual Entry — REQ-7)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/library/igdb/search?q=valorant",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "library", "igdb", "search"],
              "query": [{ "key": "q", "value": "valorant" }]
            },
            "description": "Queries the IGDB API (via cached backend proxy) for non-Steam game metadata: box art, title, platform tags, release date (REQ-7)."
          }
        },
        {
          "name": "Add Manual Game (Omni-Library — REQ-7)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"igdbId\": \"1234\",\n    \"title\": \"Valorant\",\n    \"coverUrl\": \"https://images.igdb.com/igdb/image/upload/t_cover_big/co2mvt.jpg\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/library/manual",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "library", "manual"]
            },
            "description": "Adds a non-Steam game to the user's Omni-Library using IGDB metadata."
          }
        },
        {
          "name": "Remove Manual Game from Omni-Library",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/library/:gameId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "library", ":gameId"],
              "variable": [{ "key": "gameId", "value": "5678" }]
            },
            "description": "Removes a manually added game from the user's Omni-Library."
          }
        },
        {
          "name": "Toggle Manual Playing Status (REQ-8)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"isPlaying\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/library/:gameId/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "library", ":gameId", "status"],
              "variable": [{ "key": "gameId", "value": "5678" }]
            },
            "description": "Toggles the 'currently playing' flag for a manual Omni-Library game. When true, broadcasts the status to The Pulse, mirroring Steam's automatic status behavior (REQ-8)."
          }
        }
      ]
    },
    {
      "name": "6. Prestige & Achievements",
      "item": [
        {
          "name": "Get My Prestige Profile (Plasma XP + Hall of Fame)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/prestige/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "prestige", "me"]
            },
            "description": "Returns the authenticated user's total Plasma XP (rarity-weighted — REQ-9), pinned Hall of Fame achievements (REQ-10), and pending manual milestone claims (REQ-11)."
          }
        },
        {
          "name": "Get User Prestige Profile (by userId)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/prestige/:userId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "prestige", ":userId"],
              "variable": [{ "key": "userId", "value": "12345" }]
            },
            "description": "Returns a peer's public Prestige data: Plasma XP total, Hall of Fame pins, and unlocked achievements. Used when navigating to another user's profile."
          }
        },
        {
          "name": "Get Prestige Achievements",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/achievements?type=steam",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "achievements"],
              "query": [{ "key": "type", "value": "steam", "description": "Options: steam, manual, all" }]
            },
            "description": "Returns the full list of the user's achievements with rarity weights and Plasma XP values. Filter by type: steam (auto-ingested) or manual (Omni-Library milestones)."
          }
        },
        {
          "name": "Update Hall of Fame (REQ-10)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"achievementIds\": [\"achv_1\", \"achv_2\", \"achv_3\"]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/prestige/me/hall-of-fame",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "prestige", "me", "hall-of-fame"]
            },
            "description": "Pins up to 5 achievements to the user's public Hall of Fame display (REQ-10). Overwrites the existing pinned set."
          }
        },
        {
          "name": "Submit Manual Milestone Claim (REQ-11 — BR-3)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"gameId\": \"5678\",\n    \"title\": \"Reached Diamond Rank\",\n    \"description\": \"Hit Diamond 1 in Valorant after 300 hours.\",\n    \"proofUrl\": \"https://example.com/screenshot.png\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/prestige/milestones",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "prestige", "milestones"]
            },
            "description": "Submits a manual milestone claim for an Omni-Library game. Claim is set to 'Pending' state and requires endorsement from at least one mutual peer (BR-3, REQ-11). A proofUrl (screenshot) is required."
          }
        },
        {
          "name": "Endorse a Pending Milestone Claim (BR-3)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/prestige/milestones/:milestoneId/endorse",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "prestige", "milestones", ":milestoneId", "endorse"],
              "variable": [{ "key": "milestoneId", "value": "milestone_abc" }]
            },
            "description": "A mutual peer endorses a pending milestone claim, moving it to 'Approved' status and awarding Plasma XP (BR-3)."
          }
        },
        {
          "name": "Get Leaderboard (REQ-9)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/leaderboard?scope=friends",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "leaderboard"],
              "query": [{ "key": "scope", "value": "friends", "description": "Options: friends, global" }]
            },
            "description": "Returns the ranked Plasma XP leaderboard. Scope 'friends' shows the user's social graph; 'global' shows platform-wide rankings."
          }
        }
      ]
    },
    {
      "name": "7. Rallies (Event Coordination)",
      "item": [
        {
          "name": "Get Upcoming Rallies (REQ-4)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
            "url": {
              "raw": "http://localhost:5000/api/rallies?view=calendar&intent=COMP",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "rallies"],
              "query": [
                { "key": "view", "value": "calendar", "description": "Options: calendar, list" },
                { "key": "intent", "value": "COMP", "description": "Intent filter: COMP, CHILL (REQ-14)" }
              ]
            },
            "description": "Returns upcoming Rally events, with UTC start times localized to the viewer's timezone (REQ-4). Supports intent-based filtering (REQ-14)."
          }
        },
        {
          "name": "Get Event Intel / Rally Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{YOUR_TOKEN_HERE}}" }],
